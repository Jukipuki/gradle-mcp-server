{
  "name": "gradle-mcp-server",
  "version": "0.5.1",
  "description": "MCP server that resolves external Java/Kotlin classes from Gradle dependencies — returns artifact coordinates and class structure in one call.",
  "type": "module",
  "bin": {
    "gradle-mcp-server": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/index.js",
    "test": "npm run build && node --test --test-concurrency=1 \"test/*.test.mjs\"",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "gradle",
    "java",
    "kotlin",
    "claude",
    "javap"
  ],
  "author": "Jukipuki",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jukipuki/gradle-mcp-server.git"
  },
  "homepage": "https://github.com/Jukipuki/gradle-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Jukipuki/gradle-mcp-server/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "adm-zip": "^0.5.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
